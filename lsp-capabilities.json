{
  "schema": "OpenQCLspCapabilities",
  "version": 1,
  "id": "gpumd-lsp",
  "software": "gpumd",
  "displayName": "GPUMD",
  "languageId": "gpumd",
  "executable": "gpumd-lsp",
  "defaultBranch": "main",
  "filePatterns": [
    "run.in",
    "nep.in"
  ],
  "maturity": "stable",
  "blockingPolicy": {
    "mode": "blocking",
    "description": "Error diagnostics block run-gate and Bohrium submission until resolved."
  },
  "capabilities": [
    "agent-envelope",
    "agent-json-cli",
    "blocking-gate",
    "code-actions",
    "completion",
    "context",
    "diagnostic-engine-v1",
    "diagnostics",
    "fix-placeholder",
    "fix-preview",
    "hover",
    "llm-wiki",
    "manifest",
    "openqc-context",
    "output-log-diagnostics",
    "rich-diagnostics",
    "routing",
    "source-provenance",
    "symbols"
  ],
  "agentCli": {
    "command": "gpumd-lsp-tool",
    "operations": [
      "capabilities",
      "check",
      "context",
      "complete",
      "hover",
      "symbols",
      "fix"
    ],
    "jsonFormat": true,
    "failOnBlocking": true
  },
  "diagnosticSchema": "diagnostics/diagnostic-engine-v1.schema.json",
  "wikiPaths": {
    "plan": "docs/LLM-WIKI-PLAN.md",
    "rawAssets": "raw/assets",
    "entities": "wiki/entities",
    "concepts": "wiki/concepts",
    "synthesis": "wiki/synthesis",
    "index": "index.md",
    "log": "log.md"
  },
  "fixturePaths": {
    "valid": [
      "tests/fixtures/valid",
      "test/fixtures/valid"
    ],
    "invalid": [
      "tests/fixtures/invalid",
      "test/fixtures/invalid"
    ],
    "logs": [
      "tests/fixtures/logs",
      "test/fixtures/logs"
    ]
  },
  "outputLogPatterns": [
    "run.out",
    "gpumd.out",
    "*.gpumd.out",
    "*.gpumd.log"
  ],
  "openqc": {
    "registryId": "gpumd-lsp",
    "repoName": "gpumd-lsp",
    "contextContract": "DSLAuthoringContext",
    "diagnosticEnvelope": "DiagnosticEnvelope/v1"
  },
  "sourceProvenance": [
    {
      "kind": "official_docs",
      "label": "GPUMD documentation",
      "url": "https://gpumd.org/"
    },
    {
      "kind": "official_docs",
      "label": "GPUMD run.in reference",
      "url": "https://gpumd.org/run_in.html"
    },
    {
      "kind": "official_docs",
      "label": "NEP potential documentation",
      "url": "https://gpumd.org/nep.html"
    },
    {
      "kind": "official_docs",
      "label": "GPUMD GitHub",
      "url": "https://github.com/brucefan1983/GPUMD"
    },
    {
      "kind": "wiki_manifest",
      "label": "GPUMD Upstream Sources Manifest",
      "path": "raw/assets/upstream-sources.md"
    }
  ]
}
